# Eugene-AI environment variables
# Preferred location: copy ../.env.example to ../.env at the slot root.
# This file is retained as a module reference only.
# NEVER commit .env or real webhook/token values.

# Model
OLLAMA_ENDPOINT=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_EMBED_MODEL=nomic-embed-text:v1
EUGENE_MODE=deterministic

# ChromaDB
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION=eugene-meddata-nexus
CHROMA_PERSIST_PATH=evidence/chroma
CHROMA_AUTH_TOKEN=REPLACE_WITH_LOCAL_CHROMA_TOKEN
CHROMA_AUTH_TOKEN_TRANSPORT_HEADER=Authorization
QUERY_TOP_K=5

# API
API_HOST=127.0.0.1
API_PORT=8000
QUERY_RATE_LIMIT_PER_MINUTE=60
DISABLE_DOCS=true
CORS_ORIGINS=http://localhost:7860

# Audit
AUDIT_LOG_PATH=evidence/audit-log.jsonl
REVIEW_LOG_PATH=evidence/review-log.jsonl
CORPUS_ALERT_LOG_PATH=evidence/corpus-alert-log.jsonl
CORPUS_OWNER_REGISTRY_PATH=config/corpus-owners.json

# Auth tokens — replace with real values; use a secret manager in production
ADMIN_TOKEN=REPLACE_WITH_REAL_TOKEN
IT_SECURITY_TOKEN=REPLACE_WITH_REAL_TOKEN
COMPLIANCE_ANALYST_TOKEN=REPLACE_WITH_REAL_TOKEN
VENDOR_RISK_TOKEN=REPLACE_WITH_REAL_TOKEN

# Slack alerting — disabled by default
SLACK_ALERTS_ENABLED=false
SLACK_WEBHOOK_URL=

# Corpus
CORPUS_MANIFEST_PATH=../CAPSTONE-2-AI-SECURITY-ASSESSMENT-LAB/target-client/fake-data/corpus-manifest.md
CORPUS_DATA_PATH=../CAPSTONE-2-AI-SECURITY-ASSESSMENT-LAB/target-client/fake-data
