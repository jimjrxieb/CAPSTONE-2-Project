# Slot 5 local environment
# Copy to .env at this same root and fill real values.
# NEVER commit .env or real webhook/token values.

# Eugene model/runtime
OLLAMA_ENDPOINT=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_EMBED_MODEL=nomic-embed-text:v1
EUGENE_MODE=deterministic

# Eugene API/chatbox
ADMIN_TOKEN=REPLACE_WITH_LOCAL_ADMIN_TOKEN
IT_SECURITY_TOKEN=REPLACE_WITH_LOCAL_IT_SECURITY_TOKEN
COMPLIANCE_ANALYST_TOKEN=REPLACE_WITH_LOCAL_COMPLIANCE_TOKEN
VENDOR_RISK_TOKEN=REPLACE_WITH_LOCAL_VENDOR_RISK_TOKEN
API_HOST=127.0.0.1
QUERY_RATE_LIMIT_PER_MINUTE=60
CORS_ORIGINS=http://localhost:7860
DISABLE_DOCS=true

# Corpus/alert routing
SLACK_ALERTS_ENABLED=false
SLACK_WEBHOOK_URL=
CORPUS_ALERT_LOG_PATH=Eugene-AI/evidence/corpus-alert-log.jsonl
CORPUS_OWNER_REGISTRY_PATH=Eugene-AI/config/corpus-owners.json

# Optional external API path, disabled by default
HAIKU_API_ENABLED=false
HAIKU_API_KEY=
